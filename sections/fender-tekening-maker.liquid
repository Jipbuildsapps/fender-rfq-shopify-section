{%- comment -%}
  FENDER RFQ — Nederlands / English
  Complete Shopify Dawn section.
  File: sections/fender-tekening-maker.liquid

  Includes:
  - Live technical drawing
  - SVG and PNG download
  - Download respects visible/hidden dimension toggles
  - Hover on toggle highlights related drawing lines/labels
  - Zigzag hole labels when labels are close together
  - Language dropdown: Nederlands / English
  - Contact/RFQ via Shopify standard /contact endpoint
  - After submit, user stays on same configurator
  - Configuration link in email opens same configurator with filled data
{%- endcomment -%}

{%- assign v = product.selected_or_first_available_variant -%}
{%- assign uid = 'fender-rfq-' | append: product.id | append: '-' | append: section.id -%}
{%- assign default_lang = section.settings.language | default: 'nl' -%}

<div id="{{ uid }}" class="frq" data-default-lang="{{ default_lang }}">
  <div class="frq__preview">
    <div class="frq__card">
      <div class="frq__head">
        <div>
          <div class="frq__headTitle" data-i18n="technical_drawing">Technische tekening</div>
          <div class="frq__headSub" data-i18n="head_sub">Configureer lengte, gaten, harthoogte en profielmaat in realtime</div>
        </div>
        <div class="frq__headMeta" data-i18n="live_configurator">Live configurator</div>
      </div>

      <div class="frq__svgWrap">
        <svg class="frq__svg" viewBox="0 0 1200 620" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Fender technical drawing">
          <defs>
            <marker id="{{ uid }}-arr" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor"></path>
            </marker>
          </defs>

          <rect class="f-fill" x="0" y="0" width="0" height="0" rx="2"></rect>
          <rect class="f-outline" x="0" y="0" width="0" height="0" rx="2"></rect>

          <line class="f-hidden" data-d="C-top"></line>
          <line class="f-hidden" data-d="C-bot"></line>

          <g class="f-hole-proj"></g>
          <g class="f-holes"></g>
          <g class="f-hole-labels"></g>

          <g class="f-dims">
            <line class="de" data-d="L-el"></line>
            <line class="de" data-d="L-er"></line>
            <line class="dl" data-d="L-line" marker-start="url(#{{ uid }}-arr)" marker-end="url(#{{ uid }}-arr)"></line>
            <text class="dt" data-d="L-text" text-anchor="middle"></text>

            <line class="de" data-d="HB-et"></line>
            <line class="de" data-d="HB-eb"></line>
            <line class="dl" data-d="HB-line" marker-start="url(#{{ uid }}-arr)" marker-end="url(#{{ uid }}-arr)"></line>
            <text class="dt" data-d="HB-text" text-anchor="middle"></text>

            <line class="de" data-d="G-el"></line>
            <line class="de" data-d="G-em"></line>
            <line class="dl" data-d="G-line" marker-start="url(#{{ uid }}-arr)" marker-end="url(#{{ uid }}-arr)"></line>
            <text class="dt" data-d="G-text" text-anchor="middle"></text>

            <line class="de" data-d="H-em"></line>
            <line class="de" data-d="H-er"></line>
            <line class="dl" data-d="H-line" marker-start="url(#{{ uid }}-arr)" marker-end="url(#{{ uid }}-arr)"></line>
            <text class="dt" data-d="H-text" text-anchor="middle"></text>

            <line class="de" data-d="GR-el"></line>
            <line class="de" data-d="GR-er"></line>
            <line class="dl" data-d="GR-line" marker-start="url(#{{ uid }}-arr)" marker-end="url(#{{ uid }}-arr)"></line>
            <text class="dt" data-d="GR-text" text-anchor="middle"></text>

            <line class="de" data-d="HC-et"></line>
            <line class="de" data-d="HC-eb"></line>
            <line class="dl" data-d="HC-line" marker-start="url(#{{ uid }}-arr)" marker-end="url(#{{ uid }}-arr)"></line>
            <text class="dt" data-d="HC-text" text-anchor="start"></text>
          </g>

          <g class="f-hole-list"></g>
          <text class="f-warn" x="600" y="603" text-anchor="middle"></text>
        </svg>
      </div>

      <div class="frq__dimTools" aria-label="Dimension toggles">
        <div class="frq__dimToolsTitle" data-i18n="show_dimensions">Toon maatlijnen</div>
        <label class="frq__dimPill"><input type="checkbox" data-frq-dim-toggle="L" checked><span>L</span></label>
        <label class="frq__dimPill"><input type="checkbox" data-frq-dim-toggle="HB" checked><span>HB</span></label>
        <label class="frq__dimPill"><input type="checkbox" data-frq-dim-toggle="G" checked><span>G</span></label>
        <label class="frq__dimPill"><input type="checkbox" data-frq-dim-toggle="H" checked><span>H</span></label>
        <label class="frq__dimPill"><input type="checkbox" data-frq-dim-toggle="GR" checked><span>GR</span></label>
        <label class="frq__dimPill"><input type="checkbox" data-frq-dim-toggle="HC" checked><span>HC</span></label>
        <label class="frq__dimPill"><input type="checkbox" data-frq-dim-toggle="CUM" checked><span data-i18n="hole_labels">Gatlabels</span></label>
        <label class="frq__dimPill"><input type="checkbox" data-frq-dim-toggle="DIA" checked><span data-i18n="diameter_label">Ø-label</span></label>
        <label class="frq__dimPill"><input type="checkbox" data-frq-dim-toggle="HLIST" checked><span data-i18n="hole_list_toggle">Gatposities lijst</span></label>
      </div>
    </div>

    <div class="frq__svgWarn" id="{{ uid }}-svgwarn" aria-live="polite"></div>
  </div>

  <div class="frq__form">
    <div class="frq__topbar">
      <h3 class="frq__title" data-i18n="maker">Technische tekening maker</h3>

      <label class="frq__language">
        <span data-i18n="language">Taal</span>
        <select class="frq__input frq__input--language" id="{{ uid }}-language">
          <option value="nl">Nederlands</option>
          <option value="en">English</option>
        </select>
      </label>
    </div>

    <div class="frq__downloadRow">
      <button class="frq__btn frq__btn--download" type="button" id="{{ uid }}-download-svg" data-i18n="download_svg">Download SVG</button>
      <button class="frq__btn frq__btn--download" type="button" id="{{ uid }}-download-png" data-i18n="download_png">Download PNG</button>
    </div>

    <div class="frq__sub" data-sub>Stel je fenderblok samen en controleer direct de technische maatvoering.</div>
    <div class="frq__success" data-success hidden></div>

    <form method="post" action="/contact" accept-charset="UTF-8" data-frq-form>
      <input type="hidden" name="form_type" value="contact">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="return_to" id="{{ uid }}-return-to" value="{{ product.url }}?contact_posted=true#{{ uid }}">

      <input type="hidden" name="contact[BEKIJK DE AFBEELDING]" id="{{ uid }}-view-image-hidden">
      <input type="hidden" name="contact[Product]" value="{{ product.title | escape }}">
      <input type="hidden" name="contact[Product URL]" value="{{ shop.url }}{{ product.url }}">
      <input type="hidden" name="contact[Variant]" id="{{ uid }}-variant-hidden" value="{{ v.title | escape }}">
      <input type="hidden" name="contact[SKU]" id="{{ uid }}-sku-hidden" value="{{ v.sku | escape }}">

      <input type="hidden" name="contact[Profielmodus]" id="{{ uid }}-profile-mode-hidden">
      <input type="hidden" name="contact[Schroefmaat]" id="{{ uid }}-thread-hidden">
      <input type="hidden" name="contact[Profielhoogte_HB_mm]" id="{{ uid }}-HB-hidden">
      <input type="hidden" name="contact[Profielbreedte_B_mm]" id="{{ uid }}-B-hidden">
      <input type="hidden" name="contact[Kamerhoogte_C_mm]" id="{{ uid }}-C-hidden">
      <input type="hidden" name="contact[Kamerbreedte_D_mm]" id="{{ uid }}-D-hidden">
      <input type="hidden" name="contact[Rechterafstand_GR_mm]" id="{{ uid }}-GR-hidden">
      <input type="hidden" name="contact[Gatposities]" id="{{ uid }}-holes-hidden">

      <textarea hidden name="contact[Technische samenvatting]" id="{{ uid }}-summary"></textarea>

      <input type="hidden" name="contact[Landingspagina]" id="{{ uid }}-trk-land">
      <input type="hidden" name="contact[Referrer]" id="{{ uid }}-trk-ref">
      <input type="hidden" name="contact[Taal_landcode]" id="{{ uid }}-trk-locale">

      <script type="application/json" id="{{ uid }}-variant-data">
      [
        {% for variant in product.variants %}
          {"id": {{ variant.id | json }}, "title": {{ variant.title | json }}, "sku": {{ variant.sku | json }}}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
      </script>

      <div class="frq__section-label" data-i18n="profile_variant">Profiel / variant</div>

      <div class="frq__row frq__row--3">
        <div>
          <label class="frq__label" for="{{ uid }}-variant-select" data-i18n="choose_variant">Kies variant *</label>
          <select class="frq__input" id="{{ uid }}-variant-select" required>
            {% for variant in product.variants %}
              <option value="{{ forloop.index0 }}" {% if variant.id == v.id %}selected{% endif %}>
                {{ variant.title | escape }}{% if variant.sku != blank %} — {{ variant.sku | escape }}{% endif %}
              </option>
            {% endfor %}
            <option value="custom" data-i18n-option="custom_height">Aangepaste hoogte</option>
          </select>
          <div class="frq__hint" id="{{ uid }}-variant-meta">Geselecteerde SKU: {{ v.sku | escape }}</div>
        </div>

        <div class="frq__customHeight" id="{{ uid }}-custom-height-wrap" hidden>
          <label class="frq__label" for="{{ uid }}-CUSTOM-HB" data-i18n="custom_hb">Aangepaste hoogte HB (mm) *</label>
          <input class="frq__input" id="{{ uid }}-CUSTOM-HB" name="contact[Aangepaste_profielhoogte_HB_mm]" type="text" inputmode="decimal" placeholder="bijv. 45" data-ph-nl="bijv. 45" data-ph-en="e.g. 45">
          <div class="frq__hint" data-i18n="custom_hint">Kamerindicatie wordt bij aangepaste hoogte niet getekend.</div>
        </div>

        <div>
          <label class="frq__label" for="{{ uid }}-L" data-i18n="length">Lengte (L) mm *</label>
          <input class="frq__input" id="{{ uid }}-L" name="contact[Lengte_mm]" type="text" inputmode="decimal" placeholder="bijv. 500" data-ph-nl="bijv. 500" data-ph-en="e.g. 500" required>
        </div>
      </div>

      <div class="frq__section-label" data-i18n="holes_dimensions">Gaten / maatvoering</div>

      <div class="frq__row frq__row--6">
        <div>
          <label class="frq__label" for="{{ uid }}-G" data-i18n="g_left">G links (mm)</label>
          <input class="frq__input" id="{{ uid }}-G" name="contact[G_links_mm]" type="text" inputmode="decimal" placeholder="bijv. 100" data-ph-nl="bijv. 100" data-ph-en="e.g. 100">
        </div>

        <div>
          <label class="frq__label" for="{{ uid }}-HH" data-i18n="h_center">H hart-op-hart (mm)</label>
          <input class="frq__input" id="{{ uid }}-HH" name="contact[H_hart_op_hart_mm]" type="text" inputmode="decimal" placeholder="bijv. 250" data-ph-nl="bijv. 250" data-ph-en="e.g. 250">
        </div>

        <div>
          <label class="frq__label" for="{{ uid }}-DIA-TYPE" data-i18n="hole_thread">Gat / schroefmaat</label>
          <select class="frq__input" id="{{ uid }}-DIA-TYPE" name="contact[Gat_keuze]">
            <option value="custom" data-i18n-option="custom_dia">Eigen Ø invullen</option>
            <option value="M6" data-dia="7">M6 — Ø 7 mm</option>
            <option value="M8" data-dia="9">M8 — Ø 9 mm</option>
            <option value="M10" data-dia="11">M10 — Ø 11 mm</option>
            <option value="M12" data-dia="13.5">M12 — Ø 13,5 mm</option>
            <option value="M16" data-dia="17.5">M16 — Ø 17,5 mm</option>
            <option value="M20" data-dia="22">M20 — Ø 22 mm</option>
            <option value="M24" data-dia="26">M24 — Ø 26 mm</option>
            <option value="M30" data-dia="33">M30 — Ø 33 mm</option>
          </select>
        </div>

        <div>
          <label class="frq__label" for="{{ uid }}-DIA" data-i18n="diameter">Gatdiameter Ø (mm)</label>
          <input class="frq__input" id="{{ uid }}-DIA" name="contact[Gatdiameter_mm]" type="text" inputmode="decimal" placeholder="bijv. 30" data-ph-nl="bijv. 30" data-ph-en="e.g. 30">
        </div>

        <div>
          <label class="frq__label" for="{{ uid }}-N" data-i18n="hole_count">Aantal gaten</label>
          <input class="frq__input" id="{{ uid }}-N" name="contact[Aantal_gaten]" type="number" min="0" step="1" placeholder="bijv. 2" data-ph-nl="bijv. 2" data-ph-en="e.g. 2">
        </div>

        <div>
          <label class="frq__label" for="{{ uid }}-HC" data-i18n="hc">HC vanaf onderzijde (mm)</label>
          <input class="frq__input" id="{{ uid }}-HC" name="contact[Hart_hoogte_gaten_mm]" type="text" inputmode="decimal" placeholder="bijv. 21" data-ph-nl="bijv. 21" data-ph-en="e.g. 21">
        </div>
      </div>

      <div class="frq__divider"></div>

      <div class="frq__section-label" data-i18n="contact_send">Contact / configuratie versturen</div>

      <div class="frq__row frq__row--3">
        <div>
          <label class="frq__label" for="{{ uid }}-name" data-i18n="name">Naam *</label>
          <input class="frq__input" id="{{ uid }}-name" name="contact[Name]" type="text" required>
        </div>

        <div>
          <label class="frq__label" for="{{ uid }}-email" data-i18n="email">E-mail *</label>
          <input class="frq__input" id="{{ uid }}-email" name="contact[email]" type="email" required>
        </div>

        <div>
          <label class="frq__label" for="{{ uid }}-phone" data-i18n="phone">Telefoon</label>
          <input class="frq__input" id="{{ uid }}-phone" name="contact[Phone]" type="tel">
        </div>
      </div>

      <div class="frq__row frq__row--2">
        <div>
          <label class="frq__label" for="{{ uid }}-qty" data-i18n="quantity">Aantal stuks</label>
          <input class="frq__input" id="{{ uid }}-qty" name="contact[Quantity]" type="number" min="1" step="1">
        </div>

        <div>
          <label class="frq__label" for="{{ uid }}-notes" data-i18n="notes">Opmerkingen</label>
          <textarea class="frq__textarea" id="{{ uid }}-notes" name="contact[Notes]" rows="3"></textarea>
        </div>
      </div>

      <button class="frq__btn" type="submit" data-i18n="submit">Tekening versturen</button>
    </form>
  </div>
</div>

<style>
#{{ uid }}{
  --frq-accent:#BF1E2D;
  --frq-accent-rgb:191,30,45;
  --frq-accent-soft:rgba(var(--frq-accent-rgb),.10);
  --frq-border:rgba(15,23,42,.12);
  --frq-muted:rgba(15,23,42,.56);
  --frq-strong:#0f172a;
  --frq-field:#f8fafc;
  width:85%;
  max-width:none;
  margin:0 auto;
  color:#2b2b2b;
}

#{{ uid }} *{
  box-sizing:border-box;
}

#{{ uid }} .frq__preview{
  margin-bottom:24px;
}

#{{ uid }} .frq__card,
#{{ uid }} .frq__form{
  box-shadow:0 18px 55px rgba(15,23,42,.08);
}

#{{ uid }} .frq__card{
  border:1px solid var(--frq-border);
  border-radius:22px;
  background:#fff;
  overflow:hidden;
}

#{{ uid }} .frq__head{
  padding:16px 20px;
  border-bottom:1px solid rgba(0,0,0,.08);
  display:flex;
  justify-content:space-between;
  align-items:baseline;
  gap:12px;
  background:radial-gradient(circle at top left,rgba(var(--frq-accent-rgb),.10),transparent 34%),linear-gradient(180deg,#fff,#fbfbfc);
}

#{{ uid }} .frq__headTitle{
  font-size:16px;
  font-weight:700;
  color:var(--frq-strong);
}

#{{ uid }} .frq__headSub{
  font-size:13px;
  color:var(--frq-muted);
  margin-top:2px;
}

#{{ uid }} .frq__headMeta{
  font-size:12px;
  white-space:nowrap;
  padding:6px 10px;
  border-radius:999px;
  background:var(--frq-accent-soft);
  color:var(--frq-accent);
  font-weight:800;
}

#{{ uid }} .frq__svg{
  width:100%;
  height:auto;
  display:block;
  background:#fff;
}

#{{ uid }} .frq__svgWrap{
  position:relative;
  background:radial-gradient(circle at top right,rgba(var(--frq-accent-rgb),.04),transparent 28%),#fff;
}

#{{ uid }} .frq__svgWarn{
  min-height:16px;
  margin-top:8px;
  font-size:13px;
  color:rgba(180,0,0,.78);
}

#{{ uid }} .f-fill{
  fill:transparent;
}

#{{ uid }} .f-outline{
  fill:none;
  stroke:currentColor;
  opacity:.65;
  stroke-width:2;
  vector-effect:non-scaling-stroke;
}

#{{ uid }} .f-hidden{
  stroke:currentColor;
  opacity:.52;
  stroke-width:1.2;
  stroke-dasharray:7 5;
  vector-effect:non-scaling-stroke;
}

#{{ uid }} .f-hole-proj-line{
  stroke:currentColor;
  opacity:.28;
  stroke-width:1;
  vector-effect:non-scaling-stroke;
}

#{{ uid }} .f-label-bg{
  fill:#fff;
  stroke:rgba(0,0,0,.08);
  stroke-width:1;
}

#{{ uid }} .f-holes circle{
  fill:#fff;
  stroke:currentColor;
  stroke-width:1.5;
  vector-effect:non-scaling-stroke;
  opacity:.86;
}

#{{ uid }} .de{
  stroke:currentColor;
  opacity:.45;
  stroke-width:1;
  vector-effect:non-scaling-stroke;
}

#{{ uid }} .dl{
  stroke:currentColor;
  opacity:.55;
  stroke-width:1;
  vector-effect:non-scaling-stroke;
}

#{{ uid }} .dt{
  fill:currentColor;
  opacity:.82;
  font-size:14px;
  font-weight:650;
  letter-spacing:.2px;
}

#{{ uid }} .f-dia-text{
  fill:currentColor;
  opacity:.82;
  font-size:13px;
  font-weight:700;
}

#{{ uid }} .f-hole-label{
  fill:currentColor;
  opacity:.86;
  font-size:13px;
  font-weight:700;
}

#{{ uid }} .f-hole-list-title{
  fill:currentColor;
  opacity:.78;
  font-size:14px;
  font-weight:750;
}

#{{ uid }} .f-hole-list-text{
  fill:currentColor;
  opacity:.72;
  font-size:13px;
  font-weight:600;
}

#{{ uid }} .f-warn{
  fill:rgba(180,0,0,.82);
  font-size:13px;
  font-weight:700;
}

#{{ uid }} .frq__dimTools{
  display:flex;
  flex-wrap:wrap;
  align-items:center;
  gap:8px;
  padding:12px 16px 16px;
  border-top:1px solid rgba(15,23,42,.08);
  background:linear-gradient(180deg,#fff,#f8fafc);
}

#{{ uid }} .frq__dimToolsTitle{
  margin-right:4px;
  font-size:12px;
  font-weight:800;
  color:rgba(15,23,42,.52);
  text-transform:uppercase;
  letter-spacing:.05em;
}

#{{ uid }} .frq__dimPill{
  display:inline-flex;
  align-items:center;
  gap:7px;
  padding:8px 12px;
  border:1px solid rgba(15,23,42,.10);
  border-radius:999px;
  background:#fff;
  font-size:12px;
  font-weight:800;
  color:rgba(15,23,42,.70);
  cursor:pointer;
  user-select:none;
  transition:background .18s ease,border-color .18s ease,color .18s ease,box-shadow .18s ease;
}

#{{ uid }} .frq__dimPill input{
  accent-color:var(--frq-accent);
  cursor:pointer;
}

#{{ uid }} .frq__dimPill:hover,
#{{ uid }} .frq__dimPill:focus-within{
  background:rgba(var(--frq-accent-rgb),.07) !important;
  border-color:rgba(var(--frq-accent-rgb),.55) !important;
  color:var(--frq-accent) !important;
  box-shadow:0 8px 18px rgba(var(--frq-accent-rgb),.10) !important;
}

#{{ uid }}.is-dim-hidden-L [data-d^="L-"],
#{{ uid }}.is-dim-hidden-HB [data-d^="HB-"],
#{{ uid }}.is-dim-hidden-G [data-d^="G-"],
#{{ uid }}.is-dim-hidden-H [data-d^="H-"],
#{{ uid }}.is-dim-hidden-GR [data-d^="GR-"],
#{{ uid }}.is-dim-hidden-HC [data-d^="HC-"],
#{{ uid }}.is-dim-hidden-CUM .f-cum-label,
#{{ uid }}.is-dim-hidden-DIA .f-dia-group,
#{{ uid }}.is-dim-hidden-HLIST .f-hole-list{
  display:none;
}

#{{ uid }}.is-hover-dim-L [data-d^="L-"],
#{{ uid }}.is-hover-dim-HB [data-d^="HB-"],
#{{ uid }}.is-hover-dim-G [data-d^="G-"],
#{{ uid }}.is-hover-dim-H [data-d^="H-"],
#{{ uid }}.is-hover-dim-GR [data-d^="GR-"],
#{{ uid }}.is-hover-dim-HC [data-d^="HC-"]{
  stroke:var(--frq-accent) !important;
  fill:var(--frq-accent) !important;
  opacity:1 !important;
}

#{{ uid }}.is-hover-dim-CUM .f-cum-label text,
#{{ uid }}.is-hover-dim-DIA .f-dia-group text,
#{{ uid }}.is-hover-dim-HLIST .f-hole-list text{
  fill:var(--frq-accent) !important;
  opacity:1 !important;
}

#{{ uid }}.is-hover-dim-CUM .f-cum-label rect,
#{{ uid }}.is-hover-dim-DIA .f-dia-group rect{
  stroke:rgba(var(--frq-accent-rgb),.35) !important;
  fill:rgba(var(--frq-accent-rgb),.06) !important;
}

#{{ uid }} .frq__form{
  border:1px solid var(--frq-border);
  border-radius:22px;
  padding:22px;
  background:radial-gradient(circle at top right,rgba(var(--frq-accent-rgb),.08),transparent 32%),linear-gradient(180deg,#fff,#fbfbfc);
}

#{{ uid }} .frq__topbar{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:16px;
  margin-bottom:10px;
}

#{{ uid }} .frq__title{
  font-size:clamp(24px,2vw,34px);
  letter-spacing:-.03em;
  color:var(--frq-strong);
  margin:0;
  line-height:1.2;
}

#{{ uid }} .frq__language{
  min-width:180px;
  display:grid;
  gap:5px;
  font-size:13px;
  font-weight:800;
  color:rgba(15,23,42,.62);
}

#{{ uid }} .frq__input--language{
