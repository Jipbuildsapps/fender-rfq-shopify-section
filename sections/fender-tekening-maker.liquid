<script>
(function(){
  var root=document.getElementById({{ uid | json }});
  if(!root||root.__frqInit)return;
  root.__frqInit=true;

  function $(sel){return root.querySelector(sel);}
  function setA(el,a,v){if(el)el.setAttribute(a,String(v));}
  function num(v){
    if(v==null)return null;
    var s=String(v).trim().replace(',','.');
    var m=s.match(/(\d+(\.\d+)?)/);
    return m?Number(m[1]):null;
  }
  function fmt(n){
    if(n==null||isNaN(n))return '';
    return String(Math.round(n*10)/10).replace('.',',');
  }
  function px(n){return Math.round(n*10)/10;}
  function qs(k){
    try{return new URLSearchParams(location.search||'').get(k)||'';}
    catch(e){return '';}
  }
  function parseProfileFromTitle(title){
    if(!title)return null;
    var s=String(title).trim();
    var m=s.match(/(\d+(?:[.,]\d+)?)\s*x\s*(\d+(?:[.,]\d+)?)\s*mm.*?d-bore\s*(\d+(?:[.,]\d+)?)\s*x\s*(\d+(?:[.,]\d+)?)\s*mm/i);
    if(!m)return null;
    return {A:num(m[1]),B:num(m[2]),C:num(m[3]),D:num(m[4]),custom:false};
  }

  var TXT={
    nl:{
      technical_drawing:'Technische tekening',
      head_sub:'Configureer lengte, gaten, harthoogte en profielmaat in realtime',
      live_configurator:'Live configurator',
      show_dimensions:'Toon maatlijnen',
      hole_labels:'Gatlabels',
      diameter_label:'Ø-label',
      hole_list_toggle:'Gatposities lijst',
      maker:'Technische tekening maker',
      language:'Taal',
      download_svg:'Download SVG',
      download_png:'Download PNG',
      profile_variant:'Profiel / variant',
      choose_variant:'Kies variant *',
      custom_height:'Aangepaste hoogte',
      custom_hb:'Aangepaste hoogte HB (mm) *',
      custom_hint:'Kamerindicatie wordt bij aangepaste hoogte niet getekend.',
      length:'Lengte (L) mm *',
      holes_dimensions:'Gaten / maatvoering',
      g_left:'G links (mm)',
      h_center:'H hart-op-hart (mm)',
      hole_thread:'Gat / schroefmaat',
      custom_dia:'Eigen Ø invullen',
      diameter:'Gatdiameter Ø (mm)',
      hole_count:'Aantal gaten',
      hc:'HC vanaf onderzijde (mm)',
      contact_send:'Contact / configuratie versturen',
      name:'Naam *',
      email:'E-mail *',
      phone:'Telefoon',
      quantity:'Aantal stuks',
      notes:'Opmerkingen',
      submit:'Tekening versturen',
      sub_default:'Stel je fenderblok samen en controleer direct de technische maatvoering.',
      selected_sku:'Geselecteerde SKU: ',
      no_sku:'Geen SKU ingesteld',
      profile_height:' · profielhoogte: ',
      not_parsed:' · let op: profielmaten niet uit titel gelezen',
      custom_height_fill:'Aangepaste hoogte: vul HB zelf in.',
      custom_profile_height:'Aangepaste profielhoogte: ',
      choose_profile:'Kies een profielvariant of vul een aangepaste profielhoogte in.',
      enter_length:'Vul minimaal de lengte en profielhoogte in om de technische tekening op te bouwen.',
      check_details:'Controleer de tekening en vul je gegevens in om de configuratie te versturen.',
      ready:'Alles staat klaar. De maatvoering, gatentabel en configuratie-URL worden meegestuurd.',
      thanks:'Bedankt. Je technische configuratie is verzonden.',
      own_dia:'Eigen Ø',
      hole_positions:'Gatposities',
      hole_height:'Hoogte gat = ',
      hole_diameter:'Diameter gat Ø = ',
      hole:'Gat ',
      holes_dont_fit:'Gaten passen niet binnen het blok — controleer G, H, Ø, HC en lengte.',
      last_outside:'De laatste gatpositie valt buiten de lengte — controleer G, H, N en L.',
      not_to_scale:'NIET OP SCHAAL',
      png_fail:'PNG downloaden is mislukt. Probeer SVG als alternatief.',
      file_suffix:'technische-tekening',
      summary_none:'Geen gatposities ingevuld'
    },
    en:{
      technical_drawing:'Technical drawing',
      head_sub:'Configure length, holes, center height and profile dimensions in real time',
      live_configurator:'Live configurator',
      show_dimensions:'Show dimensions',
      hole_labels:'Hole labels',
      diameter_label:'Ø label',
      hole_list_toggle:'Hole position list',
      maker:'Technical drawing generator',
      language:'Language',
      download_svg:'Download SVG',
      download_png:'Download PNG',
      profile_variant:'Profile / variant',
      choose_variant:'Choose variant *',
      custom_height:'Custom height',
      custom_hb:'Custom height HB (mm) *',
      custom_hint:'The chamber indication is not drawn for custom height.',
      length:'Length (L) mm *',
      holes_dimensions:'Holes / dimensions',
      g_left:'G left (mm)',
      h_center:'H center-to-center (mm)',
      hole_thread:'Hole / screw size',
      custom_dia:'Enter custom Ø',
      diameter:'Hole diameter Ø (mm)',
      hole_count:'Number of holes',
      hc:'HC from bottom edge (mm)',
      contact_send:'Contact / send configuration',
      name:'Name *',
      email:'Email *',
      phone:'Phone',
      quantity:'Quantity',
      notes:'Notes',
      submit:'Send drawing',
      sub_default:'Configure your fender block and instantly check the technical dimensions.',
      selected_sku:'Selected SKU: ',
      no_sku:'No SKU set',
      profile_height:' · profile height: ',
      not_parsed:' · note: profile dimensions could not be read from title',
      custom_height_fill:'Custom height: enter HB manually.',
      custom_profile_height:'Custom profile height: ',
      choose_profile:'Choose a profile variant or enter a custom profile height.',
      enter_length:'Enter at least the length and profile height to generate the technical drawing.',
      check_details:'Check the drawing and enter your details to send the configuration.',
      ready:'Everything is ready. The dimensions, hole table and configuration URL will be included.',
      thanks:'Thank you. Your technical configuration has been sent.',
      own_dia:'Custom Ø',
      hole_positions:'Hole positions',
      hole_height:'Hole height = ',
      hole_diameter:'Hole diameter Ø = ',
      hole:'Hole ',
      holes_dont_fit:'Holes do not fit inside the block — check G, H, Ø, HC and length.',
      last_outside:'The last hole position is outside the length — check G, H, N and L.',
      not_to_scale:'NOT TO SCALE',
      png_fail:'PNG download failed. Please try SVG instead.',
      file_suffix:'technical-drawing',
      summary_none:'No hole positions entered'
    }
  };

  var currentLang=(root.getAttribute('data-default-lang')==='en')?'en':'nl';
  var languageEl=$('#{{ uid }}-language');

  function tr(k){
    return (TXT[currentLang]&&TXT[currentLang][k])||TXT.nl[k]||k;
  }

  var variantSelectEl=$('#{{ uid }}-variant-select');
  var variantMetaEl=$('#{{ uid }}-variant-meta');
  var variantHiddenEl=$('#{{ uid }}-variant-hidden');
  var skuHiddenEl=$('#{{ uid }}-sku-hidden');
  var variantDataEl=$('#{{ uid }}-variant-data');
  var customHbWrapEl=$('#{{ uid }}-custom-height-wrap');
  var customHbEl=$('#{{ uid }}-CUSTOM-HB');

  var lenEl=$('#{{ uid }}-L');
  var gEl=$('#{{ uid }}-G');
  var hhEl=$('#{{ uid }}-HH');
  var diaTypeEl=$('#{{ uid }}-DIA-TYPE');
  var diaEl=$('#{{ uid }}-DIA');
  var nEl=$('#{{ uid }}-N');
  var hcEl=$('#{{ uid }}-HC');
  var qtyEl=$('#{{ uid }}-qty');
  var nameEl=$('#{{ uid }}-name');
  var emailEl=$('#{{ uid }}-email');
  var downloadSvgBtn=$('#{{ uid }}-download-svg');
  var downloadPngBtn=$('#{{ uid }}-download-png');

  var modeHiddenEl=$('#{{ uid }}-profile-mode-hidden');
  var threadHiddenEl=$('#{{ uid }}-thread-hidden');
  var hbHiddenEl=$('#{{ uid }}-HB-hidden');
  var bHiddenEl=$('#{{ uid }}-B-hidden');
  var cHiddenEl=$('#{{ uid }}-C-hidden');
  var dHiddenEl=$('#{{ uid }}-D-hidden');
  var grHiddenEl=$('#{{ uid }}-GR-hidden');
  var holesHiddenEl=$('#{{ uid }}-holes-hidden');
  var summEl=$('#{{ uid }}-summary');
  var viewImageEl=$('#{{ uid }}-view-image-hidden');
  var returnToEl=$('#{{ uid }}-return-to');
  var subEl=$('[data-sub]');
  var sucEl=$('[data-success]');
  var svgWarn=$('#{{ uid }}-svgwarn');

  var variants=[];
  var selectedVariant=null;
  var selectedProfile=null;
  var lastGR=null;
  var lastHoleRows=[];

  try{
    variants=JSON.parse((variantDataEl&&variantDataEl.textContent)||'[]');
  }catch(e){
    variants=[];
  }

  var svg=root.querySelector('.frq__svg');
  var fFill=svg.querySelector('.f-fill');
  var fOutline=svg.querySelector('.f-outline');
  var fHolesG=svg.querySelector('.f-holes');
  var fProjG=svg.querySelector('.f-hole-proj');
  var fLabelsG=svg.querySelector('.f-hole-labels');
  var fListG=svg.querySelector('.f-hole-list');
  var fWarnTxt=svg.querySelector('.f-warn');

  var DIM={};
  svg.querySelectorAll('[data-d]').forEach(function(el){
    DIM[el.getAttribute('data-d')]=el;
  });

  function applyLanguage(){
    root.querySelectorAll('[data-i18n]').forEach(function(el){
      var k=el.getAttribute('data-i18n');
      el.textContent=tr(k);
    });

    root.querySelectorAll('[data-i18n-option]').forEach(function(el){
      var k=el.getAttribute('data-i18n-option');
      el.textContent=tr(k);
    });

    root.querySelectorAll('[data-ph-nl]').forEach(function(el){
      el.setAttribute('placeholder',currentLang==='en'?el.getAttribute('data-ph-en'):el.getAttribute('data-ph-nl'));
    });

    if(languageEl)languageEl.value=currentLang;
  }

  root.querySelectorAll('.frq__dimPill').forEach(function(label){
    var input=label.querySelector('[data-frq-dim-toggle]');
    if(!input)return;

    var key=input.getAttribute('data-frq-dim-toggle');

    function applyToggle(){
      root.classList.toggle('is-dim-hidden-'+key,!input.checked);
    }

    function hoverOn(){
      root.classList.add('is-hover-dim-'+key);
    }

    function hoverOff(){
      root.classList.remove('is-hover-dim-'+key);
    }

    input.addEventListener('change',applyToggle);
    label.addEventListener('mouseenter',hoverOn);
    label.addEventListener('mouseleave',hoverOff);
    label.addEventListener('focusin',hoverOn);
    label.addEventListener('focusout',hoverOff);

    applyToggle();
  });

  if(languageEl){
    languageEl.addEventListener('change',function(){
      currentLang=this.value==='en'?'en':'nl';
      applyLanguage();
      render();
    });
  }

  function getVariantIndexById(id){
    if(!id)return -1;
    id=String(id);
    for(var i=0;i<variants.length;i++){
      if(String(variants[i].id)===id)return i;
    }
    return -1;
  }

  function getVariantIndexBySku(sku){
    if(!sku)return -1;
    sku=String(sku).toLowerCase();
    for(var i=0;i<variants.length;i++){
      if(String(variants[i].sku||'').toLowerCase()===sku)return i;
    }
    return -1;
  }

  function isCustomProfile(){
    return variantSelectEl&&String(variantSelectEl.value)==='custom';
  }

  function buildCustomProfile(){
    var hb=num(customHbEl&&customHbEl.value);
    return hb>0?{A:hb,B:null,C:null,D:null,custom:true}:null;
  }

  function getThreadLabel(){
    return !diaTypeEl?'':String(diaTypeEl.value||'')==='custom'?tr('own_dia'):String(diaTypeEl.value||'');
  }

  function updateSelectedProfileFromState(){
    if(isCustomProfile()){
      selectedVariant={id:'',title:tr('custom_height'),sku:''};
      selectedProfile=buildCustomProfile();

      if(customHbWrapEl)customHbWrapEl.hidden=false;
      if(variantHiddenEl)variantHiddenEl.value=tr('custom_height');
      if(skuHiddenEl)skuHiddenEl.value='';

      if(variantMetaEl){
        variantMetaEl.textContent=selectedProfile?tr('custom_profile_height')+fmt(selectedProfile.A)+' mm':tr('custom_height_fill');
      }
    }
  }

  function applyVariantByIndex(index){
    if(!variantSelectEl)return;

    if(String(index)==='custom'){
      variantSelectEl.value='custom';
      selectedVariant={id:'',title:tr('custom_height'),sku:''};
      selectedProfile=buildCustomProfile();

      if(customHbWrapEl)customHbWrapEl.hidden=false;
      if(variantHiddenEl)variantHiddenEl.value=tr('custom_height');
      if(skuHiddenEl)skuHiddenEl.value='';
      if(variantMetaEl)variantMetaEl.textContent=tr('custom_height_fill');

      updateHiddenProfileFields();
      render();
      return;
    }

    if(!variants.length)return;

    index=Number(index);
    if(isNaN(index)||index<0||index>=variants.length)index=0;

    variantSelectEl.value=String(index);
    selectedVariant=variants[index];
    selectedProfile=parseProfileFromTitle(selectedVariant.title);

    if(customHbWrapEl)customHbWrapEl.hidden=true;
    if(variantHiddenEl)variantHiddenEl.value=selectedVariant.title||'';
    if(skuHiddenEl)skuHiddenEl.value=selectedVariant.sku||'';

    if(variantMetaEl){
      var txt=selectedVariant.sku?tr('selected_sku')+selectedVariant.sku:tr('no_sku');
      if(selectedProfile&&selectedProfile.A)txt+=tr('profile_height')+fmt(selectedProfile.A)+' mm';
      if(!selectedProfile)txt+=tr('not_parsed');
      variantMetaEl.textContent=txt;
    }

    updateHiddenProfileFields();
    render();
  }

  function updateHiddenProfileFields(){
    if(modeHiddenEl)modeHiddenEl.value=(selectedProfile&&selectedProfile.custom)?tr('custom_height'):'Variant';
    if(threadHiddenEl)threadHiddenEl.value=getThreadLabel();
    if(hbHiddenEl)hbHiddenEl.value=selectedProfile&&selectedProfile.A?fmt(selectedProfile.A):'';
    if(bHiddenEl)bHiddenEl.value=selectedProfile&&selectedProfile.B?fmt(selectedProfile.B):'';
    if(cHiddenEl)cHiddenEl.value=selectedProfile&&selectedProfile.C?fmt(selectedProfile.C):'';
    if(dHiddenEl)dHiddenEl.value=selectedProfile&&selectedProfile.D?fmt(selectedProfile.D):'';
    if(grHiddenEl)grHiddenEl.value=lastGR!=null?fmt(lastGR):'';
    if(holesHiddenEl)holesHiddenEl.value=lastHoleRows.join(' | ');
  }

  function fillTracking(){
    var el;

    el=$('#{{ uid }}-trk-land');
    if(el)el.value=location.href;

    el=$('#{{ uid }}-trk-ref');
    if(el)el.value=document.referrer||'';

    el=$('#{{ uid }}-trk-locale');
    if(el)el.value=(navigator.language||'')+' / configurator='+currentLang;
  }

  function checkPosted(){
    if(!sucEl)return;

    try{
      if(new URLSearchParams(location.search||'').get('contact_posted')==='true'){
        sucEl.hidden=false;
        sucEl.textContent=tr('thanks');
      }
    }catch(e){}
  }

  function buildConfigUrl(){
    var url=new URL(location.href);
    var p=url.searchParams;

    if(isCustomProfile()){
      p.set('frq_profile','custom');
      p.delete('frq_variant');
      p.delete('frq_sku');

      if(customHbEl&&customHbEl.value){
        p.set('frq_CUSTOM_HB',customHbEl.value);
      }else{
        p.delete('frq_CUSTOM_HB');
      }
    }else{
      p.delete('frq_profile');
      p.delete('frq_CUSTOM_HB');

      if(selectedVariant&&selectedVariant.id)p.set('frq_variant',selectedVariant.id);
      if(selectedVariant&&selectedVariant.sku)p.set('frq_sku',selectedVariant.sku);
    }

    if(diaTypeEl&&diaTypeEl.value)p.set('frq_DIA_TYPE',diaTypeEl.value);

    p.set('frq_lang',currentLang);

    var fields={
      frq_L:lenEl&&lenEl.value,
      frq_G:gEl&&gEl.value,
      frq_H:hhEl&&hhEl.value,
      frq_DIA:diaEl&&diaEl.value,
      frq_N:nEl&&nEl.value,
      frq_HC:hcEl&&hcEl.value,
      frq_QTY:qtyEl&&qtyEl.value
    };

    Object.keys(fields).forEach(function(k){
      var v=String(fields[k]||'').trim();
      if(v)p.set(k,v);
      else p.delete(k);
    });

    p.delete('contact_posted');

    return url.toString();
  }

  function updateReturnTo(){
    if(!returnToEl)return;

    try{
      var returnUrl=new URL(location.href);
      returnUrl.searchParams.set('contact_posted','true');
      returnUrl.searchParams.set('frq_lang',currentLang);
      returnUrl.hash={{ uid | json }};
      returnToEl.value=returnUrl.pathname+returnUrl.search+returnUrl.hash;
    }catch(e){
      returnToEl.value={{ product.url | json }}+'?contact_posted=true#{{ uid }}';
    }
  }

  function updateSub(){
    if(!subEl)return;

    var L=num(lenEl&&lenEl.value);
    var HB=selectedProfile&&selectedProfile.A;
    var n=String((nameEl&&nameEl.value)||'').trim();
    var e=String((emailEl&&emailEl.value)||'').trim();

    if(!selectedVariant){
      subEl.textContent=tr('choose_profile');
    }else if(!(L>0&&HB>0)){
      subEl.textContent=tr('enter_length');
    }else if(!(n.length>0&&e.indexOf('@')>0)){
      subEl.textContent=tr('check_details');
    }else{
      subEl.textContent=tr('ready');
    }
  }

  function updateSummary(){
    var configUrl=buildConfigUrl();

    updateReturnTo();

    if(viewImageEl)viewImageEl.value=configUrl;
    if(!summEl)return;

    var profileTitle=(selectedVariant&&selectedVariant.title)||'';
    var profileMode=isCustomProfile()?tr('custom_height'):'Variant';
    var sku=(selectedVariant&&selectedVariant.sku)||'';

    var HB=(selectedProfile&&selectedProfile.A)?fmt(selectedProfile.A):'';
    var B=(selectedProfile&&selectedProfile.B)?fmt(selectedProfile.B):'';
    var C=(selectedProfile&&selectedProfile.C)?fmt(selectedProfile.C):'';
    var D=(selectedProfile&&selectedProfile.D)?fmt(selectedProfile.D):'';

    var L=num(lenEl&&lenEl.value);
    var G=num(gEl&&gEl.value);
    var HH=num(hhEl&&hhEl.value);
    var DIA=num(diaEl&&diaEl.value);
    var N=num(nEl&&nEl.value);
    var HC=num(hcEl&&hcEl.value);

    summEl.value=[
      'BEKIJK DE AFBEELDING:',
      configUrl,
      '',
      'TECHNISCHE MAATVOERING',
      'Taal: '+currentLang,
      'Profiel: '+profileTitle,
      'Profielmodus: '+profileMode,
      'SKU: '+sku,
      'HB profielhoogte: '+HB+' mm',
      'B profielbreedte: '+B+' mm',
      'C kamerhoogte: '+C+' mm',
      'D kamerbreedte: '+D+' mm',
      '',
      'BLOK / GATEN',
      'L lengte: '+(L?fmt(L):'')+' mm',
      'G links: '+(G?fmt(G):'')+' mm',
      'H hart-op-hart: '+(HH?fmt(HH):'')+' mm',
      'GR rechts: '+(lastGR!=null?fmt(lastGR):'')+' mm',
      'Gatkeuze: '+getThreadLabel(),
      'Gatdiameter: Ø '+(DIA?fmt(DIA):'')+' mm',
      'Aantal gaten: '+(N?fmt(N):''),
      'HC vanaf onderzijde: '+(HC?fmt(HC):'')+' mm',
      '',
      'GATPOSITIES',
      lastHoleRows.length?lastHoleRows.join('\n'):tr('summary_none')
    ].join('\n');
  }

  function dimOff(key){
    var el=DIM[key];
    if(!el)return;

    el.style.display='none';

    if(el.tagName&&el.tagName.toLowerCase()==='text'){
      el.textContent='';
      el.removeAttribute('transform');
    }else{
      setA(el,'x1',0);
      setA(el,'y1',0);
      setA(el,'x2',0);
      setA(el,'y2',0);
    }
  }

  function resetAll(){
    setA(fFill,'x',0);
    setA(fFill,'y',0);
    setA(fFill,'width',0);
    setA(fFill,'height',0);

    setA(fOutline,'x',0);
    setA(fOutline,'y',0);
    setA(fOutline,'width',0);
    setA(fOutline,'height',0);

    fHolesG.innerHTML='';
    fProjG.innerHTML='';
    fLabelsG.innerHTML='';
    fListG.innerHTML='';

    lastHoleRows=[];

    if(fWarnTxt)fWarnTxt.textContent='';
    if(svgWarn)svgWarn.textContent='';

    [
      'L-el','L-er','L-line','L-text',
      'HB-et','HB-eb','HB-line','HB-text',
      'G-el','G-em','G-line','G-text',
      'H-em','H-er','H-line','H-text',
      'GR-el','GR-er','GR-line','GR-text',
      'C-top','C-bot',
      'HC-et','HC-eb','HC-line','HC-text'
    ].forEach(dimOff);
  }

  function line(key,x1,y1,x2,y2){
    var el=DIM[key];
    if(!el)return;
    setA(el,'x1',px(x1));
    setA(el,'y1',px(y1));
    setA(el,'x2',px(x2));
    setA(el,'y2',px(y2));
    el.style.display='';
  }

  function text(key,x,y,t,anchor){
    var el=DIM[key];
    if(!el)return;
    el.textContent=t;
    setA(el,'x',px(x));
    setA(el,'y',px(y));
    if(anchor)setA(el,'text-anchor',anchor);
    el.style.display='';
  }

  function dimLine(k1,k2,k3,k4,x1,y1,x2,y2,ydim,label){
    line(k1,x1,y1,x1,ydim);
    line(k2,x2,y2,x2,ydim);
    line(k3,x1,ydim,x2,ydim);
    text(k4,(x1+x2)/2,ydim-8,label,'middle');
  }

  function addText(parent,cls,x,y,t,anchor){
    var NS='http://www.w3.org/2000/svg';
    var el=document.createElementNS(NS,'text');
    el.setAttribute('class',cls);
    el.setAttribute('x',px(x));
    el.setAttribute('y',px(y));
    if(anchor)el.setAttribute('text-anchor',anchor);
    el.textContent=t;
    parent.appendChild(el);
    return el;
  }

  function addLabel(parent,cls,x,y,t,anchor,groupCls){
    var NS='http://www.w3.org/2000/svg';
    var g=document.createElementNS(NS,'g');
    if(groupCls)g.setAttribute('class',groupCls);
    parent.appendChild(g);

    var w=Math.max(34,String(t).length*7.2+12);

    var r=document.createElementNS(NS,'rect');
    r.setAttribute('class','f-label-bg');
    r.setAttribute('x',px(anchor==='middle'?x-w/2:x-5));
    r.setAttribute('y',px(y-14));
    r.setAttribute('width',px(w));
    r.setAttribute('height',18);
    r.setAttribute('rx',3);
    g.appendChild(r);

    return addText(g,cls,x,y,t,anchor);
  }

  function renderHoleList(fx,fy,fW,fH,rows,hcValue,diaValue){
    if(!rows.length)return;

    var x=fx;
    var y=fy+fH+128;

    addText(fListG,'f-hole-list-title',x,y,tr('hole_positions'),'start');
    addText(fListG,'f-hole-list-text',x,y+26,tr('hole_height')+fmt(hcValue)+' mm · '+tr('hole_diameter')+fmt(diaValue)+' mm','start');

    rows.forEach(function(row,i){
      var col=Math.floor(i/4);
      var r=i%4;
      addText(fListG,'f-hole-list-text',x+col*220,y+66+r*28,row,'start');
    });
  }

  function render(){
    updateSelectedProfileFromState();
    resetAll();

    var L=num(lenEl&&lenEl.value);
    var HB=selectedProfile&&selectedProfile.A?selectedProfile.A:null;
    var chamberC=selectedProfile&&!selectedProfile.custom&&selectedProfile.C?selectedProfile.C:null;
    var G=num(gEl&&gEl.value);
    var HH=num(hhEl&&hhEl.value);
    var DIA=num(diaEl&&diaEl.value);
    var N=num(nEl&&nEl.value);
    var HC=num(hcEl&&hcEl.value);

    lastGR=null;

    if(N!=null)N=Math.max(0,Math.round(N));

    updateSub();

    if(!(L>0)||!(HB>0)){
      updateHiddenProfileFields();
      updateSummary();
      return;
    }

    var SVG_W=1200;
    var SVG_H=620;
    var PAD_L=95;
    var PAD_R=190;
    var PAD_T=105;
    var PAD_B=305;

    var maxFW=SVG_W-PAD_L-PAD_R;
    var maxFH=SVG_H-PAD_T-PAD_B;

    var scale=Math.min(maxFW/L,maxFH/HB);
    var fW=L*scale;
    var fH=HB*scale;
    var clamped=false;

    if(fW<50){
      fW=50;
      clamped=true;
    }

    if(fH<28){
      fH=28;
      clamped=true;
    }

    var fx=PAD_L+(maxFW-fW)/2;
    var fy=PAD_T+(maxFH-fH)/2;

    setA(fFill,'x',fx);
    setA(fFill,'y',fy);
    setA(fFill,'width',fW);
    setA(fFill,'height',fH);

    setA(fOutline,'x',fx);
    setA(fOutline,'y',fy);
    setA(fOutline,'width',fW);
    setA(fOutline,'height',fH);

    if(chamberC>0&&chamberC<HB){
      var cH=chamberC*scale;
      var yC1=fy+(fH-cH)/2;
      var yC2=yC1+cH;

      line('C-top',fx,yC1,fx+fW,yC1);
      line('C-bot',fx,yC2,fx+fW,yC2);
    }

    dimLine('L-el','L-er','L-line','L-text',fx,fy,fx+fW,fy,fy-72,'L = '+fmt(L)+' mm');

    var xDimH=fx-52;
    var midY=fy+fH/2;

    line('HB-et',xDimH,fy,fx,fy);
    line('HB-eb',xDimH,fy+fH,fx,fy+fH);
    line('HB-line',xDimH,fy,xDimH,fy+fH);

    var hbText=DIM['HB-text'];
    if(hbText){
      hbText.removeAttribute('transform');
      hbText.setAttribute('transform','rotate(-90,'+px(xDimH-12)+','+px(midY)+')');
      text('HB-text',xDimH-12,midY+5,'HB = '+fmt(HB)+' mm','middle');
    }

    var hasHoles=G>0&&DIA>0&&N>0;
    var holeRows=[];
    var positions=[];
    var holeCy=null;
    var first=null;
    var second=null;
    var last=null;
    var holeFitWarn=false;

    if(hasHoles){
      var NS='http://www.w3.org/2000/svg';
      var rH=(DIA/2)*scale;

      holeCy=HC>0?fy+fH-HC*scale:fy+fH/2;

      for(var i=0;i<N;i++){
        if(i>0&&!(HH>0))break;

        var dist=G+i*(HH||0);
        var cx=fx+dist*scale;

        if(i===0)first={x:cx,dist:dist};
        if(i===1)second={x:cx,dist:dist};

        last={x:cx,dist:dist};
        positions.push({x:cx,dist:dist});

        lastHoleRows.push(tr('hole')+(i+1)+': '+fmt(dist)+' mm');
        holeRows.push(tr('hole')+(i+1)+': '+fmt(dist)+' mm');

        var labelY=fy-14;

        if(positions.length>1){
          var prev=positions[positions.length-2];
          var closeToPrevious=Math.abs(cx-prev.x)<64;

          if(closeToPrevious){
            labelY=(i%2===0)?fy-14:fy+fH+24;
          }
        }

        addLabel(fLabelsG,'f-hole-label',cx,labelY,fmt(dist)+' mm','middle','f-cum-label');

        if(cx-rH<fx+2||cx+rH>fx+fW-2||holeCy-rH<fy+2||holeCy+rH>fy+fH-2){
          holeFitWarn=true;
          continue;
        }

        var c=document.createElementNS(NS,'circle');
        c.setAttribute('cx',px(cx));
        c.setAttribute('cy',px(holeCy));
        c.setAttribute('r',px(rH));
        fHolesG.appendChild(c);
      }

      if(holeFitWarn&&svgWarn){
        svgWarn.textContent=tr('holes_dont_fit');
      }
    }

    if(hasHoles&&positions.length){
      var yH=fy+fH+42;
      var yG=fy+fH+74;

      dimLine('G-el','G-em','G-line','G-text',fx,fy+fH,first.x,holeCy,yG,'G = '+fmt(G)+' mm');

      if(second&&HH>0){
        dimLine('H-em','H-er','H-line','H-text',first.x,holeCy,second.x,holeCy,yH,'H = '+fmt(HH)+' mm');
      }

      var GR=L-last.dist;
      lastGR=GR>0?GR:null;

      if(GR>0){
        dimLine('GR-el','GR-er','GR-line','GR-text',last.x,holeCy,fx+fW,fy+fH,yG,'GR = '+fmt(GR)+' mm');
      }else if(svgWarn&&last.dist>L){
        svgWarn.textContent=tr('last_outside');
      }

      if(DIA>0&&first){
        var diaLabel=(getThreadLabel()!==tr('own_dia')?getThreadLabel()+' / ':'')+'Ø '+fmt(DIA)+' mm';
        addLabel(fLabelsG,'f-dia-text',first.x,holeCy-(DIA/2)*scale-10,diaLabel,'middle','f-dia-group');
      }

      var xHC=fx+fW+92;
      var yBot=fy+fH;
      var hcVal=HC>0?HC:HB/2;

      line('HC-et',last.x,holeCy,xHC,holeCy);
      line('HC-eb',last.x,yBot,xHC,yBot);
      line('HC-line',xHC,holeCy,xHC,yBot);
      text('HC-text',xHC+8,(holeCy+yBot)/2+5,'HC = '+fmt(hcVal)+' mm','start');
    }

    if(clamped&&fWarnTxt){
      fWarnTxt.textContent=tr('not_to_scale');
    }

    renderHoleList(fx,fy,fW,fH,holeRows,(HC>0?HC:HB/2),DIA);

    updateHiddenProfileFields();
    updateSummary();
  }

  function loadFromUrl(){
    var profile=qs('frq_profile');
    var variantId=qs('frq_variant');
    var variantSku=qs('frq_sku');
    var lang=qs('frq_lang');
    var idx=-1;

    if(lang==='en'||lang==='nl')currentLang=lang;

    if(profile==='custom'){
      if(variantSelectEl)variantSelectEl.value='custom';
      if(customHbEl&&qs('frq_CUSTOM_HB'))customHbEl.value=qs('frq_CUSTOM_HB');
    }else{
      if(variantId)idx=getVariantIndexById(variantId);
      if(idx<0&&variantSku)idx=getVariantIndexBySku(variantSku);
      if(idx>=0&&variantSelectEl)variantSelectEl.value=String(idx);
    }

    var map={
      frq_L:lenEl,
      frq_G:gEl,
      frq_H:hhEl,
      frq_DIA:diaEl,
      frq_N:nEl,
      frq_HC:hcEl,
      frq_QTY:qtyEl
    };

    Object.keys(map).forEach(function(k){
      var el=map[k];
      var v=qs(k);
      if(el&&v)el.value=v;
    });

    var diaType=qs('frq_DIA_TYPE');

    if(diaType&&diaTypeEl){
      for(var i=0;i<diaTypeEl.options.length;i++){
        if(String(diaTypeEl.options[i].value)===String(diaType)){
          diaTypeEl.value=diaType;
          break;
        }
      }
    }
  }

  function applyDiaType(){
    if(!diaTypeEl||!diaEl)return;

    var opt=diaTypeEl.options[diaTypeEl.selectedIndex];
    var dia=opt?opt.getAttribute('data-dia'):'';

    if(dia){
      diaEl.value=dia;
      diaEl.readOnly=true;
    }else{
      diaEl.readOnly=false;
    }

    render();
  }

  function getDownloadFileBaseName(){
    var productTitle={{ product.title | json }} || 'fender';
    var clean=String(productTitle).toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'') || 'fender';
    return clean+'-'+tr('file_suffix');
  }

  function applyDownloadVisibility(clone){
    var hiddenMap={
      L:'[data-d^="L-"]',
      HB:'[data-d^="HB-"]',
      G:'[data-d^="G-"]',
      H:'[data-d^="H-"]',
      GR:'[data-d^="GR-"]',
      HC:'[data-d^="HC-"]',
      CUM:'.f-cum-label',
      DIA:'.f-dia-group',
      HLIST:'.f-hole-list'
    };

    Object.keys(hiddenMap).forEach(function(key){
      if(root.classList.contains('is-dim-hidden-'+key)){
        clone.querySelectorAll(hiddenMap[key]).forEach(function(el){
          el.setAttribute('display','none');
          el.style.display='none';
        });
      }
    });

    clone.querySelectorAll('.f-hole-proj, .f-hole-proj-line').forEach(function(el){
      el.setAttribute('display','none');
      el.style.display='none';
    });
  }

  function buildDownloadSvgClone(){
    render();
    updateHiddenProfileFields();
    updateSummary();

    var clone=svg.cloneNode(true);
    clone.setAttribute('xmlns','http://www.w3.org/2000/svg');
    clone.setAttribute('width','1200');
    clone.setAttribute('height','620');
    clone.setAttribute('style','background:#fff;color:#111827;');

    applyDownloadVisibility(clone);

    var css=[
      'svg{background:#fff;color:#111827}',
      '.f-fill{fill:transparent}',
      '.f-outline{fill:none;stroke:#111827;opacity:.65;stroke-width:2;vector-effect:non-scaling-stroke}',
      '.f-hidden{stroke:#111827;opacity:.52;stroke-width:1.2;stroke-dasharray:7 5;vector-effect:non-scaling-stroke}',
      '.f-hole-proj,.f-hole-proj-line{display:none!important}',
      '.f-label-bg{fill:#fff;stroke:rgba(0,0,0,.08);stroke-width:1}',
      '.f-holes circle{fill:#fff;stroke:#111827;stroke-width:1.5;vector-effect:non-scaling-stroke;opacity:.86}',
      '.de{stroke:#111827;opacity:.45;stroke-width:1;vector-effect:non-scaling-stroke}',
      '.dl{stroke:#111827;opacity:.55;stroke-width:1;vector-effect:non-scaling-stroke}',
      '.dt{fill:#111827;opacity:.82;font-size:14px;font-weight:650;letter-spacing:.2px;font-family:Arial,Helvetica,sans-serif}',
      '.f-dia-text{fill:#111827;opacity:.82;font-size:13px;font-weight:700;font-family:Arial,Helvetica,sans-serif}',
      '.f-hole-label{fill:#111827;opacity:.86;font-size:13px;font-weight:700;font-family:Arial,Helvetica,sans-serif}',
      '.f-hole-list-title{fill:#111827;opacity:.78;font-size:14px;font-weight:750;font-family:Arial,Helvetica,sans-serif}',
      '.f-hole-list-text{fill:#111827;opacity:.72;font-size:13px;font-weight:600;font-family:Arial,Helvetica,sans-serif}',
      '.f-warn{fill:rgba(180,0,0,.82);font-size:13px;font-weight:700;font-family:Arial,Helvetica,sans-serif}'
    ].join('');

    var style=document.createElementNS('http://www.w3.org/2000/svg','style');
    style.textContent=css;
    clone.insertBefore(style,clone.firstChild);

    return clone;
  }

  function serializeDownloadSvg(){
    var data=new XMLSerializer().serializeToString(buildDownloadSvgClone());
    if(data.indexOf('<?xml')!==0){
      data='<?xml version="1.0" encoding="UTF-8"?>\n'+data;
    }
    return data;
  }

  function downloadBlob(data,type,filename){
    var blob=new Blob([data],{type:type});
    var url=URL.createObjectURL(blob);
    var a=document.createElement('a');

    a.href=url;
    a.download=filename;

    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);

    setTimeout(function(){
      URL.revokeObjectURL(url);
    },1000);
  }

  function downloadSvg(){
    downloadBlob(serializeDownloadSvg(),'image/svg+xml;charset=utf-8',getDownloadFileBaseName()+'.svg');
  }

  function downloadPng(){
    var data=serializeDownloadSvg();
    var svgBlob=new Blob([data],{type:'image/svg+xml;charset=utf-8'});
    var url=URL.createObjectURL(svgBlob);
    var img=new Image();

    img.onload=function(){
      var scale=2;
      var canvas=document.createElement('canvas');

      canvas.width=1200*scale;
      canvas.height=620*scale;

      var ctx=canvas.getContext('2d');
      ctx.fillStyle='#ffffff';
      ctx.fillRect(0,0,canvas.width,canvas.height);
      ctx.drawImage(img,0,0,canvas.width,canvas.height);

      URL.revokeObjectURL(url);

      canvas.toBlob(function(blob){
        if(!blob)return;

        var pngUrl=URL.createObjectURL(blob);
        var a=document.createElement('a');

        a.href=pngUrl;
        a.download=getDownloadFileBaseName()+'.png';

        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);

        setTimeout(function(){
          URL.revokeObjectURL(pngUrl);
        },1000);
      },'image/png');
    };

    img.onerror=function(){
      URL.revokeObjectURL(url);
      alert(tr('png_fail'));
    };

    img.src=url;
  }

  loadFromUrl();
  applyLanguage();
  fillTracking();
  checkPosted();

  [lenEl,gEl,hhEl,diaEl,nEl,hcEl,customHbEl,qtyEl,nameEl,emailEl].forEach(function(el){
    if(!el)return;
    el.addEventListener('input',render,{passive:true});
    el.addEventListener('change',render,{passive:true});
  });

  if(diaTypeEl){
    diaTypeEl.addEventListener('change',applyDiaType);
  }

  if(variantSelectEl){
    variantSelectEl.addEventListener('change',function(){
      applyVariantByIndex(this.value);
    });
  }

  if(downloadSvgBtn){
    downloadSvgBtn.addEventListener('click',downloadSvg);
  }

  if(downloadPngBtn){
    downloadPngBtn.addEventListener('click',downloadPng);
  }

  var form=root.querySelector('[data-frq-form]');

  if(form){
    form.addEventListener('submit',function(){
      render();
      updateHiddenProfileFields();
      updateSummary();
      fillTracking();
    });
  }

  if(diaTypeEl&&diaTypeEl.value!=='custom'){
    applyDiaType();
  }

  if(variantSelectEl&&String(variantSelectEl.value)==='custom'){
    applyVariantByIndex('custom');
  }else if(variants.length){
    var initialIndex=variantSelectEl?Number(variantSelectEl.value):0;
    if(isNaN(initialIndex))initialIndex=0;
    applyVariantByIndex(initialIndex);
  }else{
    render();
  }
})();
</script>

